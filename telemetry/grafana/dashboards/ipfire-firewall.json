{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "IPFire firewall drop time-series, top blocked IPs, top Suricata rules, and threat-trace correlation panel",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Firewall Drops per Minute",
      "description": "Count of FORWARDFW DROP events per minute from IPFire syslog (DASH-02)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum(count_over_time({job=\"ipfire-syslog\"} |= \"FORWARDFW\" [1m]))",
          "legendFormat": "drops/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "title": "Top 10 Blocked Source IPs (24h)",
      "description": "Top 10 source IPs in FORWARDFW DROP events from IPFire syslog (DASH-04a). IP extracted from SRC= field at query time.",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "topk(10,\n  sum by (src_ip) (\n    count_over_time(\n      {job=\"ipfire-syslog\"} |= \"FORWARDFW\"\n      | regexp `SRC=(?P<src_ip>\\d+\\.\\d+\\.\\d+\\.\\d+)`\n      [24h]\n    )\n  )\n)",
          "legendFormat": "{{src_ip}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "footer": {
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "transformations": []
    },
    {
      "id": 3,
      "title": "Top 10 Triggered Suricata Rules (24h)",
      "description": "Top 10 most-triggered Suricata alert signatures from EVE JSON stream (DASH-04b). signature IS a Loki label on the suricata-eve stream.",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "topk(10,\n  sum by (signature) (\n    count_over_time({job=\"suricata-eve\", event_type=\"alert\"}[24h])\n  )\n)",
          "legendFormat": "{{signature}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "footer": {
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "transformations": []
    },
    {
      "id": 4,
      "title": "Threat Trace: $src_ip across Firewall + IDS",
      "description": "Enter a source IP in the src_ip variable above to trace across both firewall drops (ipfire-syslog) and IDS alerts (suricata-eve). Shows all log entries containing that IP from both streams. (DASH-01)",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "{job=~\"ipfire-syslog|suricata-eve\"} |= \"$src_ip\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Ascending",
        "wrapLogMessage": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ipfire", "firewall", "suricata"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "description": "Enter a source IP to trace across firewall drops and IDS alerts",
        "hide": 0,
        "label": "Source IP to trace",
        "name": "src_ip",
        "options": [
          {
            "selected": true,
            "text": "",
            "value": ""
          }
        ],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "IPFire Firewall and IDS Overview",
  "uid": "ipfire-firewall",
  "version": 1
}
