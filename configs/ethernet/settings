# /var/ipfire/ethernet/settings
# IPFire Zone-to-NIC Configuration
# Generated by: Phase 1, Plan 02
#
# SETUP REQUIRED:
#   1. Replace each MAC placeholder value with actual MAC addresses from docs/nic-map.md
#   2. Replace FILL_IN_IP_ADDRESS with actual IP addresses for your network
#   3. Replace FILL_IN_NETMASK with correct netmask (e.g., 255.255.255.0)
#
# Deployment:
#   Review this file carefully before copying.
#   Copying a misconfigured ethernet/settings to /var/ipfire/ethernet/settings
#   will disrupt networking. Use the IPFire 'setup' utility as a fallback.
#   scp configs/ethernet/settings root@IPFIRE_IP:/var/ipfire/ethernet/settings
#   Then: /etc/init.d/network restart
#
# Note: For initial bridge configuration, use 'setup' utility on IPFire console
# to set GREEN_MODE=Bridge and GREEN_SLAVES. Then export the resulting
# /var/ipfire/ethernet/settings to this file for git tracking.

# Zone configuration type
# 1=GREEN+RED, 3=GREEN+RED+ORANGE, 4=GREEN+RED+BLUE+ORANGE
CONFIG_TYPE=4

# RED zone — WAN / internet uplink
RED_DEV=red0
RED_MACADDR=a8:b8:e0:09:83:3b
RED_DRIVER=igc
RED_TYPE=DHCP
RED_ADDRESS=0.0.0.0
RED_NETMASK=0.0.0.0

# GREEN zone — Primary trusted LAN (with bridge for ports 5 and 6)
GREEN_DEV=green0
GREEN_MACADDR=a8:b8:e0:09:83:39
GREEN_DRIVER=igc
GREEN_ADDRESS=192.168.1.1
GREEN_NETMASK=255.255.255.0
GREEN_NETADDRESS=192.168.1.0
GREEN_BROADCAST=192.168.1.255
GREEN_MODE=Bridge
GREEN_SLAVES=green1,green2

# BLUE zone — Wireless / guest network
BLUE_DEV=blue0
BLUE_MACADDR=a8:b8:e0:09:83:3a
BLUE_DRIVER=igc
BLUE_ADDRESS=192.168.2.1
BLUE_NETMASK=255.255.255.0

# ORANGE zone — DMZ
ORANGE_DEV=orange0
ORANGE_MACADDR=a8:b8:e0:09:83:3c
ORANGE_DRIVER=igc
ORANGE_ADDRESS=192.168.3.1
ORANGE_NETMASK=255.255.255.0

# Bridge slave NIC 1 (bridged to green0)
# Note: green1 and green2 do not need their own zone config blocks —
# they are enslaved to green0 via GREEN_SLAVES above.
# Their MACs are tracked in the udev rules and nic-map.md.
