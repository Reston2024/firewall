# /var/ipfire/backup/include.user
# IPFire backup include list — files added to IPFire backup in addition to /var/ipfire/
# Generated by: Phase 1, Plan 02
#
# These files are in /etc/ and are NOT covered by IPFire's default backup scope.
# Without this list, they would be lost after a backup-restore cycle.
#
# Deployment:
#   scp configs/firewall/backup-include.user root@IPFIRE_IP:/var/ipfire/backup/include.user
#
# Verification (run on IPFire):
#   backupctrl list | grep -E '(udev|firewall.local)'
#
# Format: one absolute path per line, with leading slash
# Source: https://www.ipfire.org/docs/configuration/system/backup (April 2024 revision)
/etc/udev/rules.d/30-persistent-network.rules
/etc/sysconfig/firewall.local
