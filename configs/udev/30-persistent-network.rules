# /etc/udev/rules.d/30-persistent-network.rules
# IPFire NIC Persistence Rules — verified by cable-plug test 2026-04-09
# Zone assignments redesigned per ADR-E04 architecture
#
# Deployment:
#   scp configs/udev/30-persistent-network.rules root@192.168.1.1:/etc/udev/rules.d/
#   Then: reboot
#
# Physical port labels: ETH0 through ETH5 (left to right on back of N100)

# ETH0 = RED (WAN — internet)
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:39", NAME="red0"

# ETH1 = ORANGE (sniffer / honeypot)
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3a", NAME="orange0"

# ETH2 = ORANGE bridge (sniffer / honeypot)
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3b", NAME="orange1"

# ETH3 = BLUE (WiFi / IoT)
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3c", NAME="blue0"

# ETH4 = GREEN (LAN — primary)
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3d", NAME="green0"

# ETH5 = GREEN bridge (LAN — secondary)
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3e", NAME="green1"
