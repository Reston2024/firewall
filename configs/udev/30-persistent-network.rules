# /etc/udev/rules.d/30-persistent-network.rules
# IPFire NIC Persistence Rules — anchors zone names to NICs by MAC address
# Generated by: Phase 1, Plan 02
#
# SETUP REQUIRED: Replace every placeholder MAC value with the actual MAC address
# from docs/nic-map.md before deploying to IPFire.
#
# Deployment:
#   scp configs/udev/30-persistent-network.rules root@IPFIRE_IP:/etc/udev/rules.d/
#   Then on IPFire: udevadm control --reload-rules && udevadm trigger
#   Then: reboot (full reboot required to confirm persistence)
#
# Verification (run on IPFire after reboot):
#   bash /root/firewall-repo/scripts/validate-nics.sh
#
# Source: IPFire community + RHEL udev consistent naming docs
# ATTR{type}=="1" matches Ethernet interfaces only (ARPHRD_ETHER = 1)
# ATTR{address} must be lowercase colon-separated MAC

# RED zone — WAN interface (connect to ISP/modem)
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3b", NAME="red0"

# GREEN zone — Primary trusted LAN interface
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:39", NAME="green0"

# BLUE zone — Wireless/guest network interface
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3a", NAME="blue0"

# ORANGE zone — DMZ interface
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3c", NAME="orange0"

# GREEN bridge member 1 — bridged to green0 for additional LAN port
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3d", NAME="green1"

# GREEN bridge member 2 — bridged to green0 for additional LAN port
ACTION=="add", SUBSYSTEM=="net", ATTR{type}=="1", ATTR{address}=="a8:b8:e0:09:83:3e", NAME="green2"
