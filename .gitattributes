# Normalize line endings — enforce LF in the repo, auto-convert on checkout
* text=auto eol=lf

# Shell scripts must always be LF (bash will break on CRLF)
*.sh text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.rules text eol=lf
*.service text eol=lf
*.toml text eol=lf
*.alloy text eol=lf

# Data/docs
*.md text eol=lf
*.json text eol=lf
*.env.example text eol=lf

# Binary — do not touch
*.png binary
*.jpg binary
*.ico binary
*.tar.gz binary
*.iso binary
